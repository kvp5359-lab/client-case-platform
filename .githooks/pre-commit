#!/usr/bin/env bash
#
# pre-commit — техдолг-трекер: предупреждает о больших файлах в коммите.
#
# Поведение:
#  - warning, НЕ блокирует коммит
#  - срабатывает только когда файл впервые перевалил порог ИЛИ вырос ещё больше
#  - игнорирует: тесты, генерированные типы, миграции, edge function index'ы
#
# Активация (один раз после клона репо):
#   git config core.hooksPath .githooks
#
# Чтобы отключить однократно:  git commit --no-verify
#

set -e

THRESHOLD=500

# Только .ts/.tsx из staged-файлов. Исключения — генерированное и тестовое.
CHANGED=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '\.(ts|tsx)$' \
  | grep -v '\.test\.' \
  | grep -v 'src/types/database\.ts$' \
  | grep -v '^supabase/migrations/' \
  || true)

if [ -z "$CHANGED" ]; then
  exit 0
fi

WARNINGS=""
while IFS= read -r FILE; do
  [ -z "$FILE" ] && continue
  [ ! -f "$FILE" ] && continue

  NEW_LINES=$(wc -l < "$FILE" | tr -d ' ')
  if [ "$NEW_LINES" -le "$THRESHOLD" ]; then
    continue
  fi

  # Сколько строк было в HEAD (если файл новый — 0)
  OLD_LINES=$(git show "HEAD:$FILE" 2>/dev/null | wc -l | tr -d ' ' || echo "0")
  OLD_LINES=${OLD_LINES:-0}

  # Молчим, если файл уже был большим и не вырос
  if [ "$OLD_LINES" -gt "$THRESHOLD" ] && [ "$NEW_LINES" -le "$OLD_LINES" ]; then
    continue
  fi

  if [ "$OLD_LINES" -eq 0 ]; then
    WARNINGS="${WARNINGS}  • ${FILE}: ${NEW_LINES} строк (новый файл)\n"
  elif [ "$OLD_LINES" -le "$THRESHOLD" ]; then
    WARNINGS="${WARNINGS}  • ${FILE}: ${NEW_LINES} строк (перевалил порог, было ${OLD_LINES})\n"
  else
    WARNINGS="${WARNINGS}  • ${FILE}: ${NEW_LINES} строк (вырос, было ${OLD_LINES})\n"
  fi
done <<< "$CHANGED"

if [ -n "$WARNINGS" ]; then
  echo ""
  echo "⚠️  В коммите файлы крупнее ${THRESHOLD} строк:"
  printf "%b" "$WARNINGS"
  echo "   Это НЕ блокировка. Если в файле смешана логика и UI — подумай о распиле."
  echo "   См. .claude/rules/audit-false-positives.md → раздел про большие файлы"
  echo "       (когда оркестратор, а когда реально надо распилить)."
  echo ""
fi

# ── Мессенджер: напоминание про ledger (НЕ блокирует) ───────────────────────
# Если в коммите тронуты файлы мессенджера, но messenger-ledger.md не обновлён —
# напомнить. Мессенджер — самый чувствительный блок, его история живёт в ledger.
MSG_TOUCHED=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '(supabase/functions/(telegram|wazzup|gmail|email-internal-send|_shared/(syncTelegram|messageSendStatus)))|src/(components|hooks)/messenger|src/services/messenger' \
  || true)
LEDGER_TOUCHED=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '\.claude/rules/messenger-ledger\.md$' || true)

if [ -n "$MSG_TOUCHED" ] && [ -z "$LEDGER_TOUCHED" ]; then
  echo ""
  echo "📓 Тронут МЕССЕНДЖЕР (самый чувствительный блок), но messenger-ledger.md не обновлён:"
  printf "%b" "$(echo "$MSG_TOUCHED" | sed 's/^/  • /')\n"
  echo "   Зафиксируй в .claude/rules/messenger-ledger.md: расследование/состояние/грабли."
  echo "   Это НЕ блокировка (обойти: git commit --no-verify), но для мессенджера — обязательная привычка."
  echo ""
fi

# ── Имена миграций: полный таймстемп YYYYMMDDHHMMSS_, не дата-только ──────────
# Дата-только префикс (20260701_foo.sql) сортируется неоднозначно относительно
# файлов того же дня с временем (20260701HHMMSS_) под `supabase db push` → на
# чистой пересборке порядок применения расходится с продом (ловили баг 2026-07-01).
NEW_MIGRATIONS=$(git diff --cached --name-only --diff-filter=A \
  | grep -E '^supabase/migrations/[^/]+\.sql$' || true)
BAD_NAMES=""
while IFS= read -r M; do
  [ -z "$M" ] && continue
  BASE=$(basename "$M")
  # ок: ровно 14 цифр + '_' ; плохо: любой другой ведущий числовой префикс
  if ! echo "$BASE" | grep -qE '^[0-9]{14}_'; then
    BAD_NAMES="${BAD_NAMES}  • ${BASE}\n"
  fi
done <<< "$NEW_MIGRATIONS"

if [ -n "$BAD_NAMES" ]; then
  echo ""
  echo "🕐 Новые миграции без полного таймстемпа YYYYMMDDHHMMSS_ :"
  printf "%b" "$BAD_NAMES"
  echo "   Переименуй в 14-значный таймстемп (напр. $(date -u +%Y%m%d%H%M%S)_описание.sql),"
  echo "   иначе порядок применения на чистой пересборке может разойтись с продом."
  echo "   Это НЕ блокировка (обойти: git commit --no-verify)."
  echo ""
fi

exit 0
