# Telegram MTProto API credentials.
# Получить можно на https://my.telegram.org/apps — нужен любой Telegram-аккаунт
# (одного «технического» хватает на весь сервис, поскольку api_id/api_hash
# идентифицируют не пользователя, а приложение). Эти значения публикуются
# в коде клиентов вроде Telegram Desktop, секретность относительная.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# 32-байтный ключ AES-256 в hex (64 символа).
# Сгенерировать: `openssl rand -hex 32`
# Используется для шифрования gramjs StringSession в БД.
# ВАЖНО: ротация этого ключа = логаут всех сессий.
MTPROTO_SESSION_ENCRYPTION_KEY=

# Supabase project credentials (тот же сервис-rolэ key, что у Edge Functions).
SUPABASE_URL=https://zjatohckcpiqmxkmfxbs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Общий секрет для запросов от Edge Functions / PG-триггера.
# Шлётся в заголовке `x-internal-secret`, без него — 401.
INTERNAL_SECRET=

# Порт HTTP-сервера (по умолчанию 3007 в docker-сети relostart_web).
PORT=3007
HOST=0.0.0.0

# Уровень логов: debug | info | warn | error
LOG_LEVEL=info
