{
  "name": "clientcase-mtproto-service",
  "version": "0.1.0",
  "description": "MTProto integration service for ClientCase — runs gramjs sessions for employees, complements Telegram Business with reactions/read-receipts/online presence.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "aws4fetch": "^1.0.20",
    "fastify": "^5.0.0",
    "pino-pretty": "^11.2.2",
    "telegram": "^2.26.22",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
